{
  "version": 2,
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/dist/index.js" },
    { "source": "/manus-storage/:path*", "destination": "/dist/index.js" },
    { "source": "/(.*)", "destination": "/dist/index.js" }
  ]
}
